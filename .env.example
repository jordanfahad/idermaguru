NEXT_PUBLIC_SITE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres.jqsgtbzjwpbqxinustgq:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.jqsgtbzjwpbqxinustgq:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Vercel AI Gateway is preferred on Vercel. Set this only if you are not using Gateway/OIDC.
# OPENAI_API_KEY=
AI_MODEL=openai/gpt-5.4
LLM_PROVIDER=mock
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_COMPATIBLE_MODEL=gpt-4.1-mini
OPENAI_COMPATIBLE_API_KEY=
IP_HASH_SALT=change-me

# Public consultation snapshots publish shopper-entered concern text at /recommendations/<slug>.
# Disabled by default for privacy (PDPL/GDPR). Re-enable only with consent + PII scrubbing.
PUBLIC_SNAPSHOTS_ENABLED=false

# Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional affiliate/tracking parameter appended to Cicabelle outbound links.
CICABELLE_UTM_SOURCE=ai-beauty-guru

# Stripe billing (SaaS plans for the embeddable widget).
# Put REAL values only in .env.local (gitignored) and Vercel env vars — never commit them.
# Secret + webhook secret are server-only; only the publishable key is exposed to the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # pk_live_... (safe to expose)
STRIPE_SECRET_KEY=                    # sk_live_... (SERVER ONLY — roll immediately if exposed)
STRIPE_WEBHOOK_SECRET=                # whsec_... from your Stripe webhook endpoint
# Stripe Price IDs — create a Product + recurring Price per plan in the Stripe Dashboard.
STRIPE_PRICE_STARTER=                 # price_...
STRIPE_PRICE_GROWTH=                  # price_...
STRIPE_PRICE_PRO=                     # price_...
